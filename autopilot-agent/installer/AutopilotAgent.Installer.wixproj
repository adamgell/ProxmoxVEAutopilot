<Project Sdk="WixToolset.Sdk/5.0.2">
  <PropertyGroup>
    <OutputType>Package</OutputType>
    <OutputName>AutopilotAgent-$(AutopilotAgentVersion)-$(RuntimeIdentifier)</OutputName>
    <DefineConstants>
      PublishDir=$(PublishDir);
      RuntimeIdentifier=$(RuntimeIdentifier);
      AutopilotAgentVersion=$(AutopilotAgentVersion)
    </DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="WixToolset.Util.wixext" Version="5.0.2" />
  </ItemGroup>
</Project>
