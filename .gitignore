.DS_Store
__pycache__/
*.pyc
.venv/
*.retry
.pytest_cache/

# Secrets — never commit the real vault
autopilot-proxmox/inventory/group_vars/all/vault.yml
output/

# docs (allow screenshots for README)
docs/superpowers/

# Session artifacts from Claude Code superpowers tooling
.superpowers/

# Superpowers worktrees (subagent-driven-development isolated workspaces)
.worktrees/

# Artifact store contents — large binary blobs, never committed
var/artifacts/store/
var/artifacts/cache/
var/artifacts/staging/
var/artifacts/index.db
!var/artifacts/.gitkeep

# User-local build configs (each developer points at their own build host).
# The *.config.example.json files stay tracked as templates.
build/build-pe-wim.config.json
build/build-install-wim.config.json

# Pester test output (emitted by Invoke-Pester -CI in the working directory)
testResults.xml

# .NET build artifacts
build/launcher/bin/
build/launcher/obj/
build/launcher-tests/bin/
build/launcher-tests/obj/
