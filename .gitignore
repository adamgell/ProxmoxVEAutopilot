.DS_Store
__pycache__/
*.pyc
.venv/
*.retry
.pytest_cache/

# Secrets — never commit the real vault
autopilot-proxmox/inventory/group_vars/all/vault.yml
output/

# docs (allow screenshots for README)
docs/superpowers/

# Session artifacts from Claude Code superpowers tooling
.superpowers/

# Superpowers worktrees (subagent-driven-development isolated workspaces)
.worktrees/

# Artifact store contents — large binary blobs, never committed
var/artifacts/store/
var/artifacts/cache/
var/artifacts/staging/
!var/artifacts/.gitkeep

# Pester test output (emitted by Invoke-Pester -CI in the working directory)
testResults.xml
