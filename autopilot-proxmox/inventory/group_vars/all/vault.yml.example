---
# Copy this file to vault.yml and fill in your credentials:
#   cp vault.yml.example vault.yml
#
# Then encrypt it:
#   ansible-vault encrypt inventory/group_vars/all/vault.yml
#
# vault.yml is gitignored and will never be committed.

# Proxmox API token (from: pveum user token add autopilot@pve ansible --privsep=0)
vault_proxmox_api_token_id: "autopilot@pve!ansible"
vault_proxmox_api_token_secret: "YOUR-TOKEN-SECRET-HERE"

# Optional: root@pam PASSWORD, used ONLY for VM config fields Proxmox
# hardcodes to require root (currently just 'args' -- needed when an OEM
# profile or sequence step sets a chassis_type override). Leave blank
# unless you use chassis-type overrides; see docs/SETUP.md.
#
# NOTE: API tokens (even root@pam!<name> with privsep=0) CANNOT set
# 'args' -- Proxmox's check is a literal string match against 'root@pam'
# that token names never satisfy. The only way is a short-lived ticket
# obtained via POST /access/ticket with password authentication. The web
# backend fetches the ticket just-in-time per provision and passes it to
# Ansible; the password itself never leaves the container's vault.
vault_proxmox_root_username: "root@pam"
vault_proxmox_root_password: ""

# Entra ID / Azure AD app registration (for hash upload via pwsh)
vault_entra_app_id: ""
vault_entra_tenant_id: ""
vault_entra_app_secret: ""

# Bearer-token signing secret for /winpe/* endpoints. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
vault_autopilot_winpe_token_secret: ""
