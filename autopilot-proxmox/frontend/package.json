{
  "name": "proxmox-ve-autopilot-console",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:ts7": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "generate:openapi": "${PYTHON:-python3} ../scripts/export_openapi_schema.py --output src/generated/openapi.json && openapi-ts"
  },
  "dependencies": {
    "@novnc/novnc": "^1.7.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@hey-api/openapi-ts": "0.97.2",
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.0.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@typescript/native-preview": "7.0.0-dev.20260518.1",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "27.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  }
}
