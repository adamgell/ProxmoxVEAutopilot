<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!-- ================================================================
       Specialize - machine identity
       ================================================================ -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64" language="neutral"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               publicKeyToken="31bf3856ad364e35" versionScope="nonSxS">
      <ComputerName>{{ specialize_computer_name }}</ComputerName>
      <TimeZone>UTC</TimeZone>
    </component>

    {{ specialize_identification_component }}
  </settings>

  <!-- ================================================================
       OOBE - suppress setup UI; OSD continuation runs from SetupComplete
       ================================================================ -->
  <settings pass="oobeSystem">

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64" language="neutral"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State"
               publicKeyToken="31bf3856ad364e35" versionScope="nonSxS">

      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <ProtectYourPC>3</ProtectYourPC>
      </OOBE>

{{ oobe_user_accounts }}

      <!-- Auto-logon is only emitted when a sequence explicitly creates
           a local admin account. SetupComplete/OSD does not depend on it. -->
{{ oobe_auto_logon }}

      {{ extra_first_logon_commands }}

    </component>

    <!-- No windowsPE pass belongs here: disk, image, and driver work has
         already happened in WinPE. This answer file only guides Windows
         mini-setup after the image boots. -->

  </settings>
</unattend>
